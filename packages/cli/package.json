{
	"name": "@nike-release-checker/cli",
	"description": "Simple terminal Nike stock checker (50+ countries)",
	"version": "0.4.1",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "tsx --localstorage-file=local.db src/index.tsx",
		"start:mock": "tsx --localstorage-file=local.db src/devEntry.ts",
		"start:debug": "cross-env LOG_LEVEL=debug tsx --localstorage-file=local.db src/index.tsx",
		"start:devtools-debug": "node --eval \"process.stderr.write('\\nOpen in Chrome to connect debugger: chrome://inspect/#devices\\n\\n')\" && cross-env LOG_LEVEL=debug tsx --localstorage-file=local.db --inspect-brk --no-warnings --experimental-network-inspection src/index.tsx",
		"start:watch": "tsx --watch-path=./src --localstorage-file=local.db src/index.tsx",
		"build": "rspack build",
		"build:sea": "node ./scripts/pack-sea.ts",
		"build:check": "node --localstorage-file=local.db dist/bundle.cjs",
		"test": "node --localstorage-file=test.db --no-warnings --experimental-test-module-mocks --test",
		"format": "npm run format:prettier",
		"format:prettier": "npm run lint:prettier -- --write",
		"lint": "npm run lint:prettier && npm run lint:ts",
		"lint:prettier": "prettier \"**/*.{json,[jt]s,[jt]sx,[cm][jt]s}\" --check --ignore-path ../../.prettierignore",
		"lint:ts": "tsc --noEmit --project tsconfig.json"
	},
	"dependencies": {
		"@nanostores/persistent": "1.3.4",
		"@nanostores/react": "1.1.0",
		"@nanostores/router": "1.0.0",
		"@nike-release-checker/sdk": "0.6.0",
		"figures": "6.1.0",
		"ink": "7.0.5",
		"ink-picture": "2.0.0",
		"ink-select-input": "6.1.0",
		"ink-spinner": "5.0.0",
		"nanostores": "1.3.0",
		"react": "19.2.7",
		"winston": "3.19.0",
		"winston-daily-rotate-file": "5.0.0"
	},
	"devDependencies": {
		"@rspack/cli": "2.0.6",
		"@rspack/core": "2.0.6",
		"@types/react": "19.2.16",
		"cross-env": "10.1.0",
		"msw": "2.14.6",
		"tsx": "4.22.4"
	},
	"engines": {
		"node": ">=26.3"
	}
}
