{
	"name": "@nike-release-checker/cli",
	"description": "Simple terminal Nike stock checker (50+ countries)",
	"version": "0.3.1",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "tsx --experimental-webstorage --localstorage-file=local.db --no-warnings src/index.tsx",
		"start:mock": "tsx --experimental-webstorage --localstorage-file=local.db --no-warnings src/devEntry.ts",
		"start:debug": "cross-env LOG_LEVEL=debug tsx --experimental-webstorage --localstorage-file=local.db --no-warnings src/index.tsx",
		"start:devtools-debug": "cross-env LOG_LEVEL=debug tsx --experimental-webstorage --localstorage-file=local.db --inspect-brk --no-warnings --experimental-network-inspection src/index.tsx",
		"start:watch": "tsx --watch-path=./src --experimental-webstorage --localstorage-file=local.db --no-warnings src/index.tsx",
		"build": "rspack build",
		"build:sea": "node ./scripts/pack-sea.ts",
		"build:check": "node --experimental-webstorage --localstorage-file=local.db dist/bundle.cjs",
		"test": "node --experimental-webstorage --localstorage-file=test.db --no-warnings --experimental-test-module-mocks --test",
		"format": "npm run format:prettier",
		"format:prettier": "npm run lint:prettier -- --write",
		"lint": "npm run lint:prettier && npm run lint:ts",
		"lint:prettier": "prettier \"**/*.{json,[jt]s,[jt]sx,[cm][jt]s}\" --check --ignore-path ../../.prettierignore",
		"lint:ts": "tsc --noEmit --project tsconfig.json"
	},
	"dependencies": {
		"@nanostores/persistent": "1.3.3",
		"@nanostores/react": "1.1.0",
		"@nanostores/router": "1.0.0",
		"@nike-release-checker/sdk": "0.3.7",
		"figures": "6.1.0",
		"ink": "7.0.0",
		"ink-picture": "1.3.5",
		"ink-select-input": "6.1.0",
		"ink-spinner": "5.0.0",
		"nanostores": "1.2.0",
		"react": "19.2.5",
		"winston": "3.19.0",
		"winston-daily-rotate-file": "5.0.0"
	},
	"devDependencies": {
		"@rspack/cli": "1.7.11",
		"@rspack/core": "1.7.11",
		"@types/react": "19.2.14",
		"cross-env": "10.1.0",
		"msw": "2.13.2",
		"postject": "1.0.0-alpha.6",
		"tsx": "4.21.0"
	}
}
