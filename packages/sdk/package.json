{
	"name": "@nike-release-checker/sdk",
	"version": "0.5.0",
	"type": "module",
	"exports": {
		".": "./index.ts",
		"./mocks": "./mocks/node.ts",
		"./mocks/handlers": "./mocks/handlers/handlers.ts"
	},
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"exports": {
			".": "./dist/index.js",
			"./mocks": "./dist/mocks/node.js",
			"./mocks/handlers": "./dist/mocks/handlers/handlers.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"check-product-feed": "node scripts/check-product-feed.ts",
		"ci:check-product-feed": "node scripts/ci-check-product-feed.ts",
		"regen:fixtures:jp": "node scripts/regenerate-product-feed-expected.ts jp",
		"regen:fixtures:us": "node scripts/regenerate-product-feed-expected.ts us",
		"regen:fixtures:gb": "node scripts/regenerate-product-feed-expected.ts gb",
		"regen:fixtures:all": "node scripts/regenerate-product-feed-expected.ts all",
		"format": "npm run format:prettier",
		"format:prettier": "npm run lint:prettier -- --write",
		"lint": "npm run lint:prettier && npm run lint:ts",
		"lint:prettier": "prettier \"**/*.{json,[jt]s,[jt]sx,[cm][jt]s}\" --check --ignore-path ../../.prettierignore",
		"lint:ts": "tsc --noEmit --project tsconfig.json",
		"test": "node --experimental-webstorage --localstorage-file=test.db --no-warnings --test"
	},
	"dependencies": {
		"valibot": "1.4.0"
	},
	"peerDependencies": {
		"msw": "^2.14.5"
	},
	"peerDependenciesMeta": {
		"msw": {
			"optional": true
		}
	}
}
